{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Zayne Labs Config",
  "theme": "mint",
  "colors": {
    "primary": "#94cb04",
    "light": "#545454",
    "dark": "#94cb04"
  },
  "favicon": "https://media.brand.dev/288cc7c4-5cef-4376-950b-bdf0083eedae.png",
  "logo": {
    "light": "https://media.brand.dev/288cc7c4-5cef-4376-950b-bdf0083eedae.png",
    "dark": "https://media.brand.dev/288cc7c4-5cef-4376-950b-bdf0083eedae.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/zayne-labs/config"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/zayne-labs/config"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation"
            ]
          },
          {
            "group": "Packages",
            "pages": [
              "packages/overview",
              "packages/eslint-config",
              "packages/prettier-config",
              "packages/tsconfig"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/eslint-setup",
              "guides/eslint-customization",
              "guides/eslint-frameworks",
              "guides/prettier-setup",
              "guides/tsconfig-setup"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "ESLint Config",
            "pages": [
              "api/eslint/factory",
              "api/eslint/configs",
              "api/eslint/cli"
            ]
          },
          {
            "group": "Prettier Config",
            "pages": [
              "api/prettier/factory",
              "api/prettier/options"
            ]
          },
          {
            "group": "TypeScript Config",
            "pages": [
              "api/tsconfig/presets"
            ]
          }
        ]
      }
    ]
  }
}
